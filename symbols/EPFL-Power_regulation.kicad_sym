			(text_box private "AC1/2\nAD\n~{AD-EN}\nBAT\nBOOT1/2\n~{CHG}\nCLAMP1/2\nCOMM1/2\nEN2\nFOD\nILIM\nPGND\nRECT\nTERM\nTS/CTRL\nEP"
